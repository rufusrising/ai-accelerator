# --------------------------------------------------------------------
# Example tfvars wiring the gateway onto an existing AI Foundry, VNet
# and Private DNS estate. Replace every placeholder before plan/apply.
#
# CROSS-REGION SCENARIO illustrated below:
#   * Private VNet lives in eastus2 (your only private network).
#   * API Center is provisioned in eastus (API Center isn't available in
#     eastus2 as of 2026-06; it has no Private Endpoint anyway).
#   * Every other resource lives in eastus2 alongside the VNet, with PEs
#     placed in the eastus2 PE subnet.
#
# If you need a different layout (e.g. Foundry in westus3, Cosmos in
# centralus), set the per-resource location overrides below. The PE for
# each one is ALWAYS created in `network.vnet_location` regardless of where
# the service itself is — Azure supports cross-region PEs for KV, Cosmos,
# Event Hub, Storage, Redis, and Cognitive Services.
# --------------------------------------------------------------------

subscription_id     = "00000000-0000-0000-0000-000000000000"
environment_name    = "dev"

# Default region for resources. APIM is FORCED to network.vnet_location
# regardless of var.location (V2 SKU subnet-integration requirement).
location            = "eastus2"

resource_group_name = "rg-aihub-dev"
name_prefix         = "aihub"

tags = {
  workload = "ai-hub-gateway"
  env      = "dev"
}

# ---- Existing Foundry (first entry is PRIMARY) ----
foundry = [
  {
    account_name        = "aif-platform-eus2-01"
    resource_group_name = "rg-foundry-shared"
    project_name        = "platform-governance"
    location            = "eastus2"
  },
]

foundry_model_deployments = [
  { name = "gpt-4o-mini",           publisher = "OpenAI", version = "2024-07-18", sku = "GlobalStandard", capacity = 100, retirement_date = "2026-09-30", foundry_index = 0 },
  { name = "gpt-4o",                publisher = "OpenAI", version = "2024-11-20", sku = "GlobalStandard", capacity = 100, retirement_date = "2026-09-30", foundry_index = 0 },
  { name = "text-embedding-3-large", publisher = "OpenAI", version = "1",         sku = "GlobalStandard", capacity = 100, foundry_index = 0 },
]

primary_foundry_embedding_model_name = "text-embedding-3-large"
foundry_api_key_secret_uri           = "" # MI auth, no api-key

# ---- BYO networking (VNet in eastus2) ----
network = {
  vnet_id                    = "/subscriptions/<sub>/resourceGroups/rg-platform-network/providers/Microsoft.Network/virtualNetworks/vnet-platform-hub-eus2"
  vnet_location              = "eastus2"   # ← drives PE location for every resource
  apim_subnet_id             = "/subscriptions/<sub>/resourceGroups/rg-platform-network/providers/Microsoft.Network/virtualNetworks/vnet-platform-hub-eus2/subnets/snet-apim"
  private_endpoint_subnet_id = "/subscriptions/<sub>/resourceGroups/rg-platform-network/providers/Microsoft.Network/virtualNetworks/vnet-platform-hub-eus2/subnets/snet-pe"
  function_app_subnet_id     = "/subscriptions/<sub>/resourceGroups/rg-platform-network/providers/Microsoft.Network/virtualNetworks/vnet-platform-hub-eus2/subnets/snet-functionapp"
}

# Private DNS zones linked to the eastus2 VNet
private_dns_zone_ids = {
  key_vault          = "/subscriptions/<sub>/resourceGroups/rg-platform-dns/providers/Microsoft.Network/privateDnsZones/privatelink.vaultcore.azure.net"
  cosmos_db          = "/subscriptions/<sub>/resourceGroups/rg-platform-dns/providers/Microsoft.Network/privateDnsZones/privatelink.documents.azure.com"
  event_hub          = "/subscriptions/<sub>/resourceGroups/rg-platform-dns/providers/Microsoft.Network/privateDnsZones/privatelink.servicebus.windows.net"
  storage_blob       = "/subscriptions/<sub>/resourceGroups/rg-platform-dns/providers/Microsoft.Network/privateDnsZones/privatelink.blob.core.windows.net"
  storage_file       = "/subscriptions/<sub>/resourceGroups/rg-platform-dns/providers/Microsoft.Network/privateDnsZones/privatelink.file.core.windows.net"
  storage_table      = "/subscriptions/<sub>/resourceGroups/rg-platform-dns/providers/Microsoft.Network/privateDnsZones/privatelink.table.core.windows.net"
  storage_queue      = "/subscriptions/<sub>/resourceGroups/rg-platform-dns/providers/Microsoft.Network/privateDnsZones/privatelink.queue.core.windows.net"
  cognitive_services = "/subscriptions/<sub>/resourceGroups/rg-platform-dns/providers/Microsoft.Network/privateDnsZones/privatelink.cognitiveservices.azure.com"
  openai             = "/subscriptions/<sub>/resourceGroups/rg-platform-dns/providers/Microsoft.Network/privateDnsZones/privatelink.openai.azure.com"
  ai_services        = "/subscriptions/<sub>/resourceGroups/rg-platform-dns/providers/Microsoft.Network/privateDnsZones/privatelink.services.ai.azure.com"
  apim_gateway       = "/subscriptions/<sub>/resourceGroups/rg-platform-dns/providers/Microsoft.Network/privateDnsZones/privatelink.azure-api.net"
  redis_enterprise   = "/subscriptions/<sub>/resourceGroups/rg-platform-dns/providers/Microsoft.Network/privateDnsZones/privatelink.redis.azure.net"
}

# ---- Cross-region overrides ----
# Leave any of these blank to inherit var.location (eastus2 above).
# Set only when the resource type isn't available in your VNet's region.
key_vault_location  = "" # default: eastus2
cosmos_location     = "" # default: eastus2
event_hub_location  = "" # default: eastus2
redis_location      = "" # default: eastus2
storage_location    = "" # default: eastus2
logic_app_location  = "" # default: eastus2 (must match VNet region — see note in module)
monitoring_location = "" # default: eastus2

# API Center — has its own location field (Bicep parity).
# Allowed regions: australiaeast, canadacentral, centralindia, eastus,
# francecentral, swedencentral, uksouth, westeurope.
# API Center has NO Private Endpoint, so cross-region is fine.
apic = {
  sku      = "Free"
  location = "eastus"   # ← different region from VNet (eastus2) is OK
}

apim = {
  # APIM v2 forces location = network.vnet_location regardless of var.location.
  sku_name              = "StandardV2"
  sku_capacity          = 1
  publisher_name        = "Platform Team"
  publisher_email       = "platform@example.com"
  use_private_endpoint  = true
  public_network_access = false
}

features = {
  enable_pii_redaction         = true
  enable_managed_redis         = true
  enable_usage_pipeline        = true
  enable_unified_ai_api        = true
  enable_api_center            = true
  enable_azure_ai_search       = true
  enable_document_intelligence = true
  enable_openai_realtime       = true
  enable_mcp_samples           = true
  enable_entra_auth            = true
  enable_jwt_auth              = true
}

entra_tenant_id = "11111111-1111-1111-1111-111111111111"
entra_client_id = "22222222-2222-2222-2222-222222222222"

# ---- Optional per-team access contracts ----
access_contracts = [
  {
    use_case = {
      business_unit = "HR"
      use_case_name = "InternalAssistant"
      environment   = "DEV"
    }
    services = [
      { code = "OAI", api_names = ["azure-openai-api"],         endpoint_secret_name = "OAI_ENDPOINT", api_key_secret_name = "OAI_KEY" },
      { code = "DOC", api_names = ["document-intelligence-api"], endpoint_secret_name = "DOC_ENDPOINT", api_key_secret_name = "DOC_KEY" },
    ]
    foundry_connection = {
      account_name        = "aif-platform-eus2-01"
      resource_group_name = "rg-foundry-shared"
      project_name        = "platform-governance"
    }
  },
]
