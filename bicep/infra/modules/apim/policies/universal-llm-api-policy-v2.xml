<policies>
    <inbound>
        <base />
        
        <!--
            Universal LLM API Policy v2
            Purpose: Routes requests to appropriate backend pools based on model selection and RBAC permissions
            
            Flow:
            1. Authenticate request (API Key always required, JWT optional per-product)
            2. Extract and validate model parameter from request payload
            3. Configure backend pools and routing rules
            4. Determine target backend pool based on model and permissions
            5. Set up authentication and route to selected backend
            6. Configure collecting usage metrics
            
            Configuration:
            - Modify allowedBackendPools for RBAC (comma-separated pool IDs, empty = all allowed)
            - Set defaultBackendPool for unmapped models (empty = return error)
            - Backend pool definitions are in frag-set-backend-pools fragment
        -->
        
        <!-- Step 1: Unified authentication (API Key + optional JWT per-product) -->
        <include-fragment fragment-id="security-handler" />
        
        <!-- Step 2: Extract and validate model parameter from request -->
        <include-fragment fragment-id="set-llm-requested-model" />

        <!-- Step 2.1: Responses API ownership enforcement (cross-API shared fragment).
             For /responses* operations: validates that response_id (URL or previous_response_id)
             belongs to the calling subscription, returns 403 on mismatch / 404 on cache miss,
             and hydrates `requestedModel` from cache so backend routing works for GET/DELETE. -->
        <include-fragment fragment-id="responses-id-security" />

        <!-- Step 4: Configure RBAC and default routing behavior -->
        <!-- RBAC: Set allowed backend pools (comma-separated pool IDs, empty = all pools allowed) -->
        <set-variable name="allowedBackendPools" value="" />
        
        <!-- Set default backend pool (empty = return error for unmapped models) -->
        <set-variable name="defaultBackendPool" value="" />

        <!-- Universal LLM API is OpenAI-compatible only. Restrict pool selection to OpenAI-compat
             pool types so that when a model name exists in both a native pool (e.g. aws-bedrock,
             gemini, anthropic) and an OpenAI-compat pool (e.g. aws-bedrock-mantle, gemini-openai),
             routing prefers the OpenAI-compat pool which has the correct URL rewrite branch in
             frag-set-backend-authorization. Native-only pools have no /chat/completions surface
             and would result in unrewritten paths reaching the provider. -->
        <set-variable name="compatiblePoolTypes" value="azure-openai,ai-foundry,aws-bedrock-mantle,gemini-openai" />

        <!-- Validate model access based on allowedModels -->
        <include-fragment fragment-id="validate-model-access" />

        <!-- Step 4: Load backend pool configurations (real pools + alias virtual pools) -->
        <include-fragment fragment-id="set-backend-pools" />

        <!-- Step 5: Determine target backend pool based on model and permissions.
             Performs MODEL ALIAS resolution as a first-class step: when `requestedModel`
             matches an alias virtual pool, it picks a member (priority/weighted) compatible
             with `compatiblePoolTypes` (set above), sets `is-alias=true`,
             `original-model-alias=<alias>`, `requestedModel=<picked member's model>`,
             `targetBackendPool=<picked member's pool>`, and exposes `alias-fallback-members`
             for the retry block below. Access control above runs against the alias name so
             admins can grant access to the alias directly without enumerating underlying models. -->
        <include-fragment fragment-id="set-target-backend-pool" />

        <!-- Step 5.1: Body rewrite for alias requests so backends see the resolved model name.
             No-op when `is-alias=false`. -->
        <include-fragment fragment-id="resolve-model-alias" />

        <!-- Step 6: Configure authentication and route to selected backend -->
        <include-fragment fragment-id="set-backend-authorization" />

        <!-- Step 6.1: Strip browser / App Service / X-Forwarded-* headers before forwarding to backend -->
        <include-fragment fragment-id="strip-backend-headers" />

        <!-- Step 7: Configure collecting usage metrics -->
        <include-fragment fragment-id="set-llm-usage" />

        <!-- CORS Configuration for AI Foundry Compatibility -->
        <include-fragment fragment-id="ai-foundry-compatibility" />
    </inbound>
    <backend>
        <!--
            Backend Retry Logic — alias-aware cross-model fallback
            Purpose: Implements retry mechanism for transient failures (429 throttling,
            5xx server errors). When the inbound request resolved through a model alias
            (`is-alias=true`), the `alias-fallback-members` JArray (built by
            `set-target-backend-pool`) carries the remaining alias members in resolution order,
            each pre-resolved to its underlying poolName / poolType / authType. The retry block
            walks `alias-fallback-members` to provide cross-model / cross-provider fallback
            transparently to the client — Universal LLM API now matches the Unified AI API for
            alias semantics.

            Configuration:
            - Retry count: 2 standard hops + one extra hop per remaining alias member.
            - Condition: 429 (throttling) or 5xx (except when backend pool is unavailable).
            - Strategy: First fast retry with zero interval, buffer request body for replay.
            - Cross-model fallback only works for pre-stream errors (response not yet committed).
        -->
        <retry count="@{
            var isAlias = context.Variables.GetValueOrDefault<bool>("is-alias", false);
            var fallback = context.Variables.GetValueOrDefault<JArray>("alias-fallback-members");
            return isAlias && fallback != null ? 2 + fallback.Count : 2;
        }" interval="0" first-fast-retry="true" condition="@(context.Response.StatusCode == 429 || (context.Response.StatusCode >= 500 && !context.Response.StatusReason.Contains("Backend pool") && !context.Response.StatusReason.Contains("is temporarily unavailable")))">
            <choose>
                <when condition="@{
                    if (!context.Variables.GetValueOrDefault<bool>("is-alias", false)) { return false; }
                    var fallback = context.Variables.GetValueOrDefault<JArray>("alias-fallback-members");
                    var idx = context.Variables.GetValueOrDefault<int>("alias-retry-index", 0);
                    return fallback != null && idx < fallback.Count;
                }">
                    <set-variable name="alias-retry-index" value="@{
                        var current = context.Variables.GetValueOrDefault<int>("alias-retry-index", 0);
                        return current + 1;
                    }" />
                    <set-variable name="alias-current-member" value="@{
                        var fallback = (JArray)context.Variables["alias-fallback-members"];
                        var idx = context.Variables.GetValueOrDefault<int>("alias-retry-index", 1) - 1;
                        return idx >= 0 && idx < fallback.Count ? (JObject)fallback[idx] : null;
                    }" />
                    <choose>
                        <when condition="@(context.Variables.GetValueOrDefault<JObject>("alias-current-member") != null)">
                            <set-variable name="requestedModel" value="@(((JObject)context.Variables["alias-current-member"])["model"].ToString())" />
                            <set-variable name="targetBackendPool" value="@(((JObject)context.Variables["alias-current-member"])["poolName"].ToString())" />
                            <set-variable name="targetPoolType" value="@(((JObject)context.Variables["alias-current-member"])["poolType"].ToString())" />
                            <set-variable name="targetAuthType" value="@{
                                var entry = (JObject)context.Variables["alias-current-member"];
                                var at = entry["authType"]?.ToString() ?? "";
                                if (!string.IsNullOrEmpty(at)) { return at; }
                                var pt = entry["poolType"]?.ToString() ?? "";
                                if (pt == "ai-foundry" || pt == "azure-openai") { return "native-backend-authorization"; }
                                if (pt == "aws-bedrock") { return "aws-sigv4"; }
                                if (pt == "aws-bedrock-mantle" || pt == "gemini-openai") { return "api-key-bearer"; }
                                if (pt == "gemini") { return "api-key-gemini"; }
                                if (pt == "anthropic") { return "api-key-anthropic"; }
                                return "native-backend-authorization";
                            }" />
                            <set-variable name="targetAuthConfigNamedValue" value="@(((JObject)context.Variables["alias-current-member"])["authConfigNamedValue"]?.ToString() ?? "")" />
                            <trace source="Alias-Fallback" severity="information">
                                <message>@($"Alias fallback hop #{context.Variables.GetValueOrDefault<int>("alias-retry-index", 0)} → model='{context.Variables.GetValueOrDefault<string>("requestedModel", "")}' pool='{context.Variables.GetValueOrDefault<string>("targetBackendPool", "")}' (status={context.Response.StatusCode})")</message>
                            </trace>
                            <include-fragment fragment-id="resolve-model-alias" />
                            <include-fragment fragment-id="set-backend-authorization" />
                        </when>
                    </choose>
                </when>
            </choose>
            <forward-request buffer-request-body="true" />
        </retry>
    </backend>
    <outbound>
        <base />
        <!-- Cache response_id → owner mapping for successful POST /responses (cross-API shared fragment). -->
        <include-fragment fragment-id="responses-id-cache-store" />
        <include-fragment fragment-id="set-response-headers" />
    </outbound>
    <on-error>
        <base />
        <!--
            Error Handling
            Purpose: Pushes custom metrics for errors to enable Azure Monitor alerts
            
            Integration: Uses raise-throttling-events fragment to send metrics to monitoring system for 429 responses
        -->
        
        <include-fragment fragment-id="raise-throttling-events" />
        <include-fragment fragment-id="set-response-headers" />
    </on-error>
</policies>