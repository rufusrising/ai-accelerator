<policies>
    <inbound>
        <base />

        <!--
            Unified AI API Policy
            Purpose: Main orchestration policy for the Unified AI Gateway that coordinates all policy
                     fragments to provide comprehensive AI model routing, authentication, rate limiting,
                     and monitoring across multiple API types and model providers.
                     
                     Uses shared fragments (set-backend-pools, set-target-backend-pool,
                     set-backend-authorization, validate-model-access, set-llm-usage) unified across
                     all 3 API flavors (Azure OpenAI, Universal LLM, Unified AI).
                     Uses Unified-AI-specific fragments (metadata-config, central-cache-manager,
                     request-processor, security-handler, path-builder, set-response-headers) for
                     wildcard routing, multi-API-type support, and JWT authentication.

            Fragment Execution Order:
            1. metadata-config: Load centralized configuration (models, api-types, timeouts) [Unified AI specific]
            2. central-cache-manager: Cache management for configuration [Unified AI specific]
            3. request-processor: Request analysis (URL routing + body parsing + model extraction) [Unified AI specific]
            4. security-handler: Frontend authentication (API Key + optional JWT) [Unified AI specific]
            5. validate-model-access: Model access control per product [SHARED]
            6. set-backend-pools: Load backend pool configurations [SHARED]
            7. set-target-backend-pool: Select target backend (with api-type override support) [SHARED]
            8. set-backend-authorization: Backend auth + set-backend-service [SHARED]
            9. path-builder: Backend path construction and URI rewriting [Unified AI specific]
            10. set-llm-usage: Token usage metrics [SHARED]
            11. set-response-headers: Response header injection (outbound) [Unified AI specific]
        -->

        <!-- Validate product context -->
        <choose>
            <when condition="@(context.Product == null)">
                <return-response>
                    <set-status code="401" reason="Unauthorized" />
                    <set-header name="Content-Type" exists-action="override">
                        <value>application/json</value>
                    </set-header>
                    <set-body>@{
                        return new JObject(
                            new JProperty("error", new JObject(
                                new JProperty("message", "Access denied. API requests must be made through a product subscription."),
                                new JProperty("code", "product_required")
                            ))
                        ).ToString();
                    }</set-body>
                </return-response>
            </when>
        </choose>

        <!-- Step 1-2: Load and cache configuration [Unified AI specific] -->
        <include-fragment fragment-id="metadata-config" />
        <include-fragment fragment-id="central-cache-manager" />

        <!-- Step 3: Analyze request - extracts api-type, requestedModel, path info, -->
        <!--         apiTypeOverrideBackend, and skipBackendUrlRewrite [Unified AI specific] -->
        <include-fragment fragment-id="request-processor" />

        <!-- Step 4: Frontend authentication (API Key + optional JWT) [Unified AI specific] -->
        <include-fragment fragment-id="security-handler" />

        <!-- Step 4.1: Responses API ownership enforcement [SHARED with Azure OpenAI / Universal LLM]
             For /responses* operations: validates that response_id (URL or previous_response_id)
             belongs to the calling subscription, returns 403 on mismatch / 404 on cache miss,
             and hydrates `requestedModel` from cache for GET/DELETE so model-based routing still works
             alongside any apiTypeOverrideBackend setting. Reuses `response-id` and `parsed-request-body`
             that frag-request-processor already extracts. -->
        <include-fragment fragment-id="responses-id-security" />

        <!-- Step 5: Model access control per product [SHARED with Azure OpenAI / Universal LLM] -->
        <include-fragment fragment-id="validate-model-access" />

        <!-- RBAC: Set allowed backend pools (comma-separated pool IDs, empty = all pools allowed) -->
        <set-variable name="allowedBackendPools" value="" />
        <!-- Set default backend pool (empty = return error for unmapped models) -->
        <set-variable name="defaultBackendPool" value="" />

        <!-- Step 6: Load backend pool configurations (real pools + alias virtual pools) [SHARED] -->
        <include-fragment fragment-id="set-backend-pools" />
        <!-- Step 6.1: Strip browser / App Service / X-Forwarded-* headers before forwarding to backend -->
        <include-fragment fragment-id="strip-backend-headers" />
        
        <!-- Step 7: Select target backend pool [SHARED]
             Performs MODEL ALIAS resolution as a first-class step: when `requestedModel` matches
             an alias virtual pool, it picks a member (priority/weighted) compatible with the
             current api-type's `compatiblePoolTypes`, sets `is-alias=true`,
             `original-model-alias=<alias>`, `requestedModel=<picked member's model>`,
             `targetBackendPool=<picked member's pool>`, and exposes `alias-fallback-members`
             for the retry block below. -->
        <include-fragment fragment-id="set-target-backend-pool" />

        <!-- Step 7.1: Body rewrite for alias requests so backends see the resolved model name.
             No-op when `is-alias=false`. The shared fragment also handles trace logging. -->
        <include-fragment fragment-id="resolve-model-alias" />

        <!-- Alias targetBackendPool to selected-backend for set-response-headers compatibility -->
        <set-variable name="selected-backend" value="@(context.Variables.GetValueOrDefault<string>("targetBackendPool", ""))" />

        <!-- Step 8: Backend auth + set-backend-service [SHARED with Azure OpenAI / Universal LLM] -->
        <!-- skipBackendUrlRewrite is set by request-processor, so URL rewriting is handled by path-builder -->
        <include-fragment fragment-id="set-backend-authorization" />

        <!-- Step 9: Build backend path and rewrite URI [Unified AI specific] -->
        <include-fragment fragment-id="path-builder" />

        <!-- Step 10: Format translation extension point [FUTURE] -->
        <!-- When format translation is added, insert a format-translator fragment here.
             It would check if the client api-type format differs from the backend's expected format
             and transform request body accordingly (e.g., OpenAI → Anthropic Messages, Bedrock Converse).
             Response body transformation would be added in the outbound section.
             <include-fragment fragment-id="format-translator" /> -->

        <!-- Step 11: Token usage metrics [SHARED with Azure OpenAI / Universal LLM] -->
        <include-fragment fragment-id="set-llm-usage" />

        <!-- CORS Configuration for AI Foundry Compatibility -->
        <include-fragment fragment-id="ai-foundry-compatibility" />

        <!-- Calculate request timeout based on model config and streaming status -->
        <set-variable name="request-timeout" value="@{
            var models = context.Variables.GetValueOrDefault<JObject>("config-models");
            var timeoutSettings = context.Variables.GetValueOrDefault<JObject>("config-timeout-settings");
            var model = context.Variables.GetValueOrDefault<string>("requestedModel", "");
            var streaming = context.Variables.GetValueOrDefault<bool>("is-streaming", false);

            // Get model-specific timeout (fallback to 120 if not configured)
            var modelConfig = models?[model];
            var baseTimeout = modelConfig?["timeout"]?.Value<int>() ?? 120;

            // Apply streaming multiplier if applicable
            if (streaming) {
                var multiplier = timeoutSettings?["streaming-multiplier"]?.Value<int>() ?? 3;
                return baseTimeout * multiplier;
            }
            return baseTimeout;
        }" />
    </inbound>
    <backend>
        <!--
            Backend Retry Logic — alias-aware cross-model fallback
            Retries on 429 (throttling) or 5xx server errors. Skips retry when the backend pool
            itself is unavailable.

            When the inbound request resolved through an alias (`is-alias=true`), the
            `alias-fallback-members` JArray (built by `set-target-backend-pool`) carries the
            remaining alias members in resolution order. Each entry is pre-resolved to its
            underlying poolName / poolType / authType / authConfigNamedValue at deploy time, so
            the retry block can swap targets across providers without re-walking the model→pool
            map. Cross-model / cross-provider fallback is therefore transparent to the client —
            the gateway tries the picked member first, then walks `alias-fallback-members`.

            Note: cross-model fallback only works for pre-stream errors. Once streaming has
            started, the response is committed and fallback is not possible.
        -->
        <retry count="@{
            var isAlias = context.Variables.GetValueOrDefault<bool>("is-alias", false);
            var fallback = context.Variables.GetValueOrDefault<JArray>("alias-fallback-members");
            // Standard retries (2) + one retry per remaining alias member.
            return isAlias && fallback != null ? 2 + fallback.Count : 2;
        }" interval="0" first-fast-retry="true" condition="@(context.Response.StatusCode == 429 || (context.Response.StatusCode >= 500 && !context.Response.StatusReason.Contains("Backend pool") && !context.Response.StatusReason.Contains("is temporarily unavailable")))">
            <!-- Cross-model alias fallback: walk `alias-fallback-members` in order. Each retry
                 hop pops the next entry, sets the targeting variables directly (no second pool
                 match needed — the entry already carries the resolved pool info), then re-runs
                 body rewrite + backend authorization + path builder. -->
            <choose>
                <when condition="@{
                    if (!context.Variables.GetValueOrDefault<bool>("is-alias", false)) { return false; }
                    var fallback = context.Variables.GetValueOrDefault<JArray>("alias-fallback-members");
                    var idx = context.Variables.GetValueOrDefault<int>("alias-retry-index", 0);
                    return fallback != null && idx < fallback.Count;
                }">
                    <set-variable name="alias-retry-index" value="@{
                        var current = context.Variables.GetValueOrDefault<int>("alias-retry-index", 0);
                        return current + 1;
                    }" />
                    <set-variable name="alias-current-member" value="@{
                        var fallback = (JArray)context.Variables["alias-fallback-members"];
                        var idx = context.Variables.GetValueOrDefault<int>("alias-retry-index", 1) - 1;
                        return idx >= 0 && idx < fallback.Count ? (JObject)fallback[idx] : null;
                    }" />
                    <choose>
                        <when condition="@(context.Variables.GetValueOrDefault<JObject>("alias-current-member") != null)">
                            <set-variable name="requestedModel" value="@(((JObject)context.Variables["alias-current-member"])["model"].ToString())" />
                            <set-variable name="targetBackendPool" value="@(((JObject)context.Variables["alias-current-member"])["poolName"].ToString())" />
                            <set-variable name="targetPoolType" value="@(((JObject)context.Variables["alias-current-member"])["poolType"].ToString())" />
                            <set-variable name="targetAuthType" value="@{
                                var entry = (JObject)context.Variables["alias-current-member"];
                                var at = entry["authType"]?.ToString() ?? "";
                                if (!string.IsNullOrEmpty(at)) { return at; }
                                var pt = entry["poolType"]?.ToString() ?? "";
                                if (pt == "ai-foundry" || pt == "azure-openai") { return "native-backend-authorization"; }
                                if (pt == "aws-bedrock") { return "aws-sigv4"; }
                                if (pt == "aws-bedrock-mantle" || pt == "gemini-openai") { return "api-key-bearer"; }
                                if (pt == "gemini") { return "api-key-gemini"; }
                                if (pt == "anthropic") { return "api-key-anthropic"; }
                                return "native-backend-authorization";
                            }" />
                            <set-variable name="targetAuthConfigNamedValue" value="@(((JObject)context.Variables["alias-current-member"])["authConfigNamedValue"]?.ToString() ?? "")" />
                            <set-variable name="selected-backend" value="@(context.Variables.GetValueOrDefault<string>("targetBackendPool", ""))" />
                            <trace source="Alias-Fallback" severity="information">
                                <message>@($"Alias fallback hop #{context.Variables.GetValueOrDefault<int>("alias-retry-index", 0)} → model='{context.Variables.GetValueOrDefault<string>("requestedModel", "")}' pool='{context.Variables.GetValueOrDefault<string>("targetBackendPool", "")}' (status={context.Response.StatusCode})")</message>
                            </trace>
                            <include-fragment fragment-id="resolve-model-alias" />
                            <include-fragment fragment-id="set-backend-authorization" />
                            <include-fragment fragment-id="path-builder" />
                        </when>
                    </choose>
                </when>
            </choose>
            <forward-request timeout="@(context.Variables.GetValueOrDefault<int>("request-timeout", 120))" buffer-request-body="true" />
        </retry>
    </backend>
    <outbound>
        <base />
        <!-- Cache response_id → owner mapping for successful POST /responses [SHARED]. -->
        <include-fragment fragment-id="responses-id-cache-store" />
        <include-fragment fragment-id="set-response-headers" />
    </outbound>
    <on-error>
        <base />
        <include-fragment fragment-id="raise-throttling-events" />
        <include-fragment fragment-id="set-response-headers" />
    </on-error>
</policies>
